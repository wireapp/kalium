<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!--
      androidx.benchmark reads this flag from the test APK manifest. It MUST be false; running
      benchmarks against a debuggable build produces meaningless numbers and the runner refuses.
    -->
    <application
        android:debuggable="false"
        tools:replace="android:debuggable" />
</manifest>
